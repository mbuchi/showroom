# ── ZITADEL OIDC (required) ─────────────────────────────────────────────────
# Vite inlines these at BUILD time — they must be set in the Vercel project's
# environment variables before the build runs, not just locally.
VITE_ZITADEL_AUTHORITY=https://your-instance.zitadel.cloud
VITE_ZITADEL_CLIENT_ID=your_client_id

# ── Mapbox geocoding (required for the /reporter address search) ────────────
# Without this the reporter's address search is disabled and the page is
# unusable (there is no manual lat/lng entry).
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token
